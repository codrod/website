{
  "name": "codrod",
  "version": "1.0.0",
  "description": "Personal website",
  "private": true,
  "keywords": [
    "Cody",
    "Rodgers"
  ],
  "license": "",
  "author": "Cody Rodgers",
  "scripts": {
    "start": "npm run clean && eleventy && webpack serve --config webpack.config.prod.js",
    "build": "npm run clean && eleventy && webpack --config webpack.config.prod.js",
    "dev": "npm-run-all --parallel dev:webpack dev:eleventy",
    "dev:webpack": "webpack serve --config webpack.config.dev.js",
    "dev:eleventy": "eleventy --serve",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@popperjs/core": "^2.11.8",
    "babel-loader": "^10.1.1",
    "bootstrap": "^5.3.8",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "glob": "^13.0.6",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.0",
    "purgecss-webpack-plugin": "^8.0.0",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "sass-embedded": "1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
}
