{
  "name": "codrod",
  "version": "1.0.0",
  "description": "Personal website",
  "private": true,
  "keywords": [
    "Cody",
    "Rodgers"
  ],
  "license": "",
  "author": "Cody Rodgers",
  "scripts": {
    "start": "npm run clean && eleventy && webpack serve --config webpack.config.prod.js",
    "build": "npm run clean && eleventy && webpack --config webpack.config.prod.js",
    "dev": "npm-run-all --parallel dev:webpack dev:eleventy",
    "dev:webpack": "webpack serve --config webpack.config.dev.js",
    "dev:eleventy": "eleventy --serve",
    "publish": "npm run build && rimraf docs && cp -r dist docs",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@popperjs/core": "^2.11.8",
    "babel-loader": "^10.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "glob-all": "^3.3.1",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.4",
    "npm-run-all": "^4.1.5",
    "postcss-loader": "^8.2.0",
    "postcss-preset-env": "^10.5.0",
    "purgecss-webpack-plugin": "^7.0.2",
    "rimraf": "^6.1.2",
    "sass": "^1.97.1",
    "sass-embedded": "1.77.5",
    "sass-loader": "^16.0.6",
    "style-loader": "^4.0.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpack-merge": "^5.10.0"
  }
}
